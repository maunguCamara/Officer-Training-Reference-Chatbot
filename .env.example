# ---- LLM Provider ----
# Set to "ollama" to use free local models (Ollama + HuggingFace)
# Set to "openai" to use OpenAI (requires API key)
LLM_PROVIDER=ollama

# ---- OpenAI (only needed if LLM_PROVIDER=openai) ----
OPENAI_API_KEY=sk-...

# ---- Meta WhatsApp Cloud API (optional if only using Twilio) ----
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# ---- Twilio ----
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886   # sandbox number

# ---- Webhooks ----
WEBHOOK_VERIFY_TOKEN=my_custom_verify_token_123

# ---- Admin ----
ADMIN_SECRET=change_me_123