# Meta WhatsApp Cloud API
# Get these from your Meta Developer app (WhatsApp > API Setup)
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Webhook verification (use any string, keep it secret)
WEBHOOK_VERIFY_TOKEN=my_custom_verify_token_123

# OpenAI (for embeddings and LLM)
OPENAI_API_KEY=sk-...

# Twilio (optional – for Twilio WhatsApp API support)
# Get these from your Twilio Console
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Admin command secret (used for /refresh command)
ADMIN_SECRET=change_me_123